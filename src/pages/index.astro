---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="VALENTINO RESTAURANT Hannover | Moldawische & Italienische Küche"
  description="VALENTINO RESTAURANT in Hannover Sahlkamp — Genuss aus Moldau und Italien. 4,9 Sterne, liebevoll zubereitete Gerichte, elegantes Ambiente. Fr–So geöffnet."
>
<style>
  .hero { min-height: 100vh; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background-image: url('/bar.jpg'); background-size: cover; background-position: center; filter: brightness(0.35); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(10,8,0,0.75) 100%); }
  .hero-content { position: relative; z-index: 1; text-align: center; padding: 2rem; max-width: 900px; }

  .photo-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 320px 320px; gap: 4px; }
  .photo-grid .item { overflow: hidden; }
  .photo-grid img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .photo-grid .item:hover img { transform: scale(1.05); }

  .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1px; background: rgba(201,168,76,0.1); }
  .menu-item { background: #1a1a1a; padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: start; gap: 1rem; transition: background 0.2s; }
  .menu-item:hover { background: #222; }

  .icon-feature { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 2rem; background: #1a1a1a; border: 1px solid rgba(201,168,76,0.2); border-radius: 4px; text-align: center; }
  .icon-circle { width: 56px; height: 56px; background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .icon-circle svg { width: 26px; height: 26px; stroke: #C9A84C; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }

  .btn-gold { display: flex; align-items: center; justify-content: center; gap: 0.75rem; background: #C9A84C; color: #0a0a0a; padding: 1.1rem 2rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.9rem; border-radius: 2px; transition: background 0.2s; }
  .btn-gold:hover { background: #E8C97A; }
  .btn-wa { display: flex; align-items: center; justify-content: center; gap: 0.75rem; background: #1fad54; color: white; padding: 1.1rem 2rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.9rem; border-radius: 2px; transition: background 0.2s; }
  .btn-wa:hover { background: #25D366; }

  @media (max-width: 640px) {
    .photo-grid { grid-template-rows: 200px 200px; }
  }
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p style="font-size:0.75rem;letter-spacing:0.5em;text-transform:uppercase;color:#C9A84C;margin-bottom:1.5rem;">Hoppelweg 2 · 30657 Hannover</p>
    <div style="width:80px;height:1px;background:#C9A84C;margin:0 auto 2rem;"></div>
    <h1 style="font-size:clamp(3.5rem,10vw,7rem);font-weight:700;line-height:1;letter-spacing:0.1em;color:#fff;text-transform:uppercase;margin-bottom:1rem;">Valentino</h1>
    <p style="font-family:'Playfair Display',serif;font-size:clamp(1rem,2.5vw,1.5rem);font-style:italic;color:#C9A84C;letter-spacing:0.25em;margin-bottom:2rem;">Restaurant</p>
    <div style="width:80px;height:1px;background:#C9A84C;margin:0 auto 2.5rem;"></div>
    <p style="font-size:clamp(0.95rem,2vw,1.15rem);opacity:0.9;max-width:560px;margin:0 auto 1rem;font-weight:300;line-height:1.9;">Moldawische &amp; Italienische Spezialitäten — zwei Küchen, eine Leidenschaft.</p>
    <div style="display:flex;align-items:center;justify-content:center;gap:0.5rem;margin-bottom:3rem;">
      <span style="color:#C9A84C;">★★★★★</span>
      <span style="font-size:0.9rem;opacity:0.8;">4,9 · 61 Bewertungen auf Google</span>
    </div>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="tel:+4917621426137" style="background:#C9A84C;color:#0a0a0a;padding:1rem 2.5rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;font-size:0.85rem;border-radius:2px;">Tisch reservieren</a>
      <a href="/#speisekarte" style="border:1px solid rgba(201,168,76,0.5);color:#C9A84C;padding:1rem 2.5rem;letter-spacing:0.15em;text-transform:uppercase;font-size:0.85rem;border-radius:2px;">Speisekarte ansehen</a>
    </div>
    <div style="margin-top:4rem;display:flex;gap:3rem;justify-content:center;flex-wrap:wrap;">
      <div style="text-align:center;"><p style="font-size:2rem;font-family:'Playfair Display',serif;color:#C9A84C;">4,9★</p><p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.6;margin-top:0.3rem;">Google Bewertung</p></div>
      <div style="width:1px;background:rgba(201,168,76,0.2);"></div>
      <div style="text-align:center;"><p style="font-size:2rem;font-family:'Playfair Display',serif;color:#C9A84C;">2</p><p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.6;margin-top:0.3rem;">Küchen</p></div>
      <div style="width:1px;background:rgba(201,168,76,0.2);"></div>
      <div style="text-align:center;"><p style="font-size:2rem;font-family:'Playfair Display',serif;color:#C9A84C;">54+</p><p style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.6;margin-top:0.3rem;">Gerichte</p></div>
    </div>
  </div>
</section>

<!-- 4 FOTOS — keine Google Maps Screenshots -->
<section>
  <div class="photo-grid">
    <div class="item"><img src="/oktopus.jpg" alt="Gegrillter Oktopus — Hausspecialität Valentino Restaurant" loading="eager" /></div>
    <div class="item"><img src="/seafood-platte.jpg" alt="Frische Meeresfrüchte Platte" loading="eager" /></div>
    <div class="item"><img src="/vorspeise.jpg" alt="Festliche Vorspeisen-Platte" loading="lazy" /></div>
    <div class="item"><img src="/torte.jpg" alt="Feiern & Events im Valentino" loading="lazy" /></div>
  </div>
</section>

<!-- ÜBER UNS -->
<section id="ueber-uns" style="padding:6rem 2rem;max-width:900px;margin:0 auto;text-align:center;">
  <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;color:#C9A84C;margin-bottom:1rem;">Unsere Geschichte</p>
  <h2 style="font-size:clamp(2rem,5vw,3rem);margin-bottom:1.5rem;line-height:1.2;">Zwei Kulturen.<br/><em style="color:#C9A84C;">Eine Küche.</em></h2>
  <div style="width:60px;height:1px;background:#C9A84C;margin:0 auto 2rem;"></div>
  <p style="font-size:1.05rem;opacity:0.85;max-width:680px;margin:0 auto 1.5rem;line-height:1.9;font-weight:300;">Im VALENTINO RESTAURANT begegnen sich zwei reiche Kochtraditionen — die herzhafte, authentische Küche Moldaus und die eleganten Klassiker Italiens. Jedes Gericht wird mit frischen Zutaten und echter Handwerkskunst zubereitet.</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.5rem;margin-top:3rem;">
    <div class="icon-feature">
      <div class="icon-circle"><svg viewBox="0 0 24 24"><path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/><line x1="6" y1="13" x2="18" y2="13"/></svg></div>
      <p style="font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;color:#C9A84C;font-weight:700;">Frische Küche</p>
      <p style="font-size:0.8rem;opacity:0.6;">Täglich frisch zubereitet</p>
    </div>
    <div class="icon-feature">
      <div class="icon-circle"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
      <p style="font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;color:#C9A84C;font-weight:700;">Mit Liebe</p>
      <p style="font-size:0.8rem;opacity:0.6;">Jedes Gericht handgemacht</p>
    </div>
    <div class="icon-feature">
      <div class="icon-circle"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
      <p style="font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;color:#C9A84C;font-weight:700;">4,9 Sterne</p>
      <p style="font-size:0.8rem;opacity:0.6;">61 Google-Bewertungen</p>
    </div>
    <div class="icon-feature">
      <div class="icon-circle"><svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
      <p style="font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;color:#C9A84C;font-weight:700;">Lieferservice</p>
      <p style="font-size:0.8rem;opacity:0.6;">Auch zum Mitnehmen</p>
    </div>
  </div>
</section>

<!-- SPEISEKARTE -->
<section id="speisekarte" style="background:#111;padding:6rem 2rem;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;color:#C9A84C;margin-bottom:1rem;">Unsere Küche</p>
      <h2 style="font-size:clamp(2rem,5vw,3rem);margin-bottom:1rem;">Highlights der Speisekarte</h2>
      <div style="width:60px;height:1px;background:#C9A84C;margin:0 auto;"></div>
    </div>
    <div style="margin-bottom:4rem;">
      <h3 style="font-size:1.4rem;color:#C9A84C;margin-bottom:0.5rem;">🇲🇩 Moldawische Spezialitäten</h3>
      <div style="width:40px;height:1px;background:rgba(201,168,76,0.4);margin-bottom:2rem;"></div>
      <div class="menu-grid">
        {[
          {name:"Placinte", desc:"Traditionelles gefülltes Brot mit Ricotta, Dill, Frühlingszwiebeln", price:"7,50"},
          {name:"Soljanka", desc:"Tomatensuppe mit Salamisorten, Oliven, Zitrone", price:"10,00"},
          {name:"Zeama", desc:"Hühnersuppe mit hausgemachten Nudeln", price:"9,00"},
          {name:"Mamaliga cu Friptura", desc:"Polenta, gebratener Schweinsnacken, Zwiebeln, Schafskäse", price:"15,90"},
          {name:"Peste cu Mujdei", desc:"Gebratener Fisch (Karpfen), Knoblauchsauce, Polenta", price:"16,90"},
          {name:"Sarmale", desc:"Kohlrouladen mit Hähnchenbrust und Reis, serviert mit Schmand", price:"13,50"},
          {name:"Pelmeni", desc:"Teigtaschen mit Fleischfüllung, mit Schmand", price:"11,90"},
          {name:"Papanasi cu Brinza", desc:"Quarkpfannkuchen mit Sahnecreme und Honig", price:"7,90"},
        ].map(item => (
          <div class="menu-item">
            <div><p style="font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.25rem;">{item.name}</p><p style="font-size:0.8rem;opacity:0.6;line-height:1.5;">{item.desc}</p></div>
            <p style="color:#C9A84C;font-weight:700;white-space:nowrap;">{item.price} €</p>
          </div>
        ))}
      </div>
    </div>
    <div style="margin-bottom:2rem;">
      <h3 style="font-size:1.4rem;color:#C9A84C;margin-bottom:0.5rem;">🇮🇹 Italienische Spezialitäten</h3>
      <div style="width:40px;height:1px;background:rgba(201,168,76,0.4);margin-bottom:1rem;"></div>
      <p style="font-size:0.8rem;opacity:0.5;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1.5rem;">Pasta</p>
      <div class="menu-grid" style="margin-bottom:2.5rem;">
        {[
          {name:"Carbonara", desc:"Nudeln, Eigelb, Parmesan, Pancetta", price:"11,90"},
          {name:"Spaghetti di Mare", desc:"Spaghetti mit Meeresfrüchten in Tomatensoße", price:"14,90"},
          {name:"Aglio, Olio e Peperoncino", desc:"Nudeln, Knoblauch, scharfe Peperoni", price:"9,90"},
          {name:"Ravioli Burro e Salvia", desc:"Teigtaschen mit Ricotta, Spinat, Salbei und Butter", price:"12,90"},
        ].map(item => (
          <div class="menu-item">
            <div><p style="font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.25rem;">{item.name}</p><p style="font-size:0.8rem;opacity:0.6;">{item.desc}</p></div>
            <p style="color:#C9A84C;font-weight:700;white-space:nowrap;">{item.price} €</p>
          </div>
        ))}
      </div>
      <p style="font-size:0.8rem;opacity:0.5;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1.5rem;">Pizza (30 cm)</p>
      <div class="menu-grid">
        {[
          {name:"Margherita", desc:"Mozzarella, Tomatensoße, Basilikum", price:"10,00"},
          {name:"Valentino ★", desc:"Mozzarella, Tomatensoße, Oktopus, Cherrytomaten", price:"15,90"},
          {name:"Parma e Rucola", desc:"Mozzarella, Parmaschinken, Rucola, Parmesan", price:"14,90"},
          {name:"Buffalina", desc:"Tomatensoße, Basilikum, Cherrytomaten, Büffelmozzarella", price:"14,90"},
          {name:"Quattro Formaggi", desc:"Mozzarella, Parmesan, Gorgonzola, Edamer Käse", price:"13,50"},
          {name:"Capricciosa", desc:"Mozzarella, Pilze, Artischocken, Oliven, Schinken, Spinat", price:"12,90"},
        ].map(item => (
          <div class="menu-item">
            <div><p style="font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.25rem;">{item.name}</p><p style="font-size:0.8rem;opacity:0.6;">{item.desc}</p></div>
            <p style="color:#C9A84C;font-weight:700;white-space:nowrap;">{item.price} €</p>
          </div>
        ))}
      </div>
    </div>
    <p style="text-align:center;font-size:0.8rem;opacity:0.5;">Alle Allergene auf Anfrage · Preise inkl. MwSt. · Speisekarte kann saisonal abweichen</p>
  </div>
</section>

<!-- BEWERTUNGEN -->
<section style="padding:6rem 2rem;max-width:1000px;margin:0 auto;">
  <div style="text-align:center;margin-bottom:4rem;">
    <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;color:#C9A84C;margin-bottom:1rem;">Was unsere Gäste sagen</p>
    <h2 style="font-size:clamp(2rem,5vw,3rem);">Stimmen aus Hannover</h2>
    <div style="width:60px;height:1px;background:#C9A84C;margin:1.5rem auto 0;"></div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
    {[
      {text:"Das Essen ist unglaublich lecker, liebevoll zubereitet und schön angerichtet.", stars:5},
      {text:"Als Vorspeise bekamen wir ein paar köstliche Häppchen vom Haus — eine wunderbare Geste.", stars:5},
      {text:"Durch Zufall auf Google Maps entdeckt und nicht enttäuscht worden. Wird nicht der letzte Besuch gewesen sein.", stars:4},
    ].map(r => (
      <div style="background:#1a1a1a;border:1px solid rgba(201,168,76,0.15);padding:2rem;border-radius:4px;">
        <p style="color:#C9A84C;font-size:1rem;margin-bottom:1rem;">{"★".repeat(r.stars)}</p>
        <p style="font-style:italic;opacity:0.85;line-height:1.7;font-size:0.95rem;">„{r.text}"</p>
        <p style="margin-top:1rem;font-size:0.75rem;opacity:0.4;letter-spacing:0.1em;">Google Bewertung</p>
      </div>
    ))}
  </div>
</section>

<!-- ÖFFNUNGSZEITEN + RESERVIERUNG -->
<section style="background:#111;padding:5rem 2rem;">
  <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:4rem;align-items:center;">
    <div>
      <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;color:#C9A84C;margin-bottom:1rem;">Öffnungszeiten</p>
      <h2 style="font-size:2rem;margin-bottom:2rem;">Wann wir<br/>für Sie da sind</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        {[
          {day:"Mo – Do", time:"Geschlossen"},
          {day:"Freitag", time:"17:00 – 22:00 Uhr", open:true},
          {day:"Samstag", time:"12:00 – 22:00 Uhr", open:true},
          {day:"Sonntag", time:"12:00 – 22:00 Uhr", open:true},
        ].map(o => (
          <div style="display:flex;justify-content:space-between;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.08);">
            <span style="font-size:0.9rem;opacity:0.7;">{o.day}</span>
            <span style={`font-size:0.9rem;${o.open ? 'color:#C9A84C;font-weight:700;' : 'opacity:0.35;'}`}>{o.time}</span>
          </div>
        ))}
      </div>
    </div>
    <div style="text-align:center;">
      <p style="font-size:0.75rem;letter-spacing:0.4em;text-transform:uppercase;color:#C9A84C;margin-bottom:1rem;">Reservierung</p>
      <h2 style="font-size:2rem;margin-bottom:1rem;">Ihren Tisch<br/>sichern</h2>
      <p style="opacity:0.7;margin-bottom:2rem;line-height:1.8;font-size:0.9rem;">Rufen Sie uns an oder schreiben Sie uns auf WhatsApp.</p>
      <div style="display:flex;flex-direction:column;gap:0.85rem;">
        <a href="tel:+4917621426137" class="btn-gold">
          <svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:none;stroke:#0a0a0a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.5 2 2 0 0 1 3.59 1.32h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          0176 21426137
        </a>
        <a href="https://wa.me/4917621426137?text=Guten%20Tag%2C%20ich%20m%C3%B6chte%20einen%20Tisch%20reservieren." target="_blank" rel="noopener" class="btn-wa">
          <svg viewBox="0 0 24 24" style="width:20px;height:20px;fill:white;flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp schreiben
        </a>
      </div>
    </div>
  </div>
</section>

<!-- GOOGLE MAPS -->
<section style="padding:0;">
  <div style="background:#1a1a1a;padding:1.5rem 2rem 0;">
    <h2 style="font-size:1.2rem;max-width:1100px;margin:0 auto;">📍 So finden Sie uns — Hoppelweg 2, 30657 Hannover</h2>
  </div>
  <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2434.5!2d9.7757587!3d52.4091219!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b00dc1493469eb%3A0x35dc4760971501a7!2sVALENTINO%20RESTAURANT!5e0!3m2!1sde!2sde!4v1"
    width="100%" height="420" style="border:0;display:block;filter:grayscale(20%);" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="VALENTINO RESTAURANT auf Google Maps">
  </iframe>
</section>
