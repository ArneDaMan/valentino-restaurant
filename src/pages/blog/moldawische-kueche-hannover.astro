<article style="padding:5rem 2rem;max-width:780px;margin:0 auto;">
  <div style="margin-bottom:3rem;">
    <a href="/blog" style="color:#C9A84C;text-decoration:none;" style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;opacity:0.6;margin-bottom:2rem;">
